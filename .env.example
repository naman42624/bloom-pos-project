# ============================================================
# BloomCart POS — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in values:
#   cp .env.example server/.env
# ============================================================

# ─── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ──────────────────────────────────────────────
# SQLite (current — for local dev without Docker):
# DATABASE_PATH=./database.sqlite

# PostgreSQL (production):
DATABASE_URL=postgresql://bloomcart:bloomcart_dev_2026@localhost:5432/bloomcart

# Connection pool size
PG_POOL_MAX=20

# ─── Authentication ────────────────────────────────────────
# IMPORTANT: Generate a strong secret for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-64-char-random-hex-string
JWT_EXPIRES_IN=7d

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── File Storage (S3 / Cloudflare R2 / MinIO) ────────────
S3_BUCKET=bloomcart-uploads
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
# CDN URL for serving uploaded files (optional)
CDN_URL=

# ─── CORS ──────────────────────────────────────────────────
# Comma-separated allowed origins (set in production)
ALLOWED_ORIGINS=*

# ─── Monitoring ────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info

# ─── Expo Push Notifications ──────────────────────────────
# Optional: for higher push throughput
EXPO_ACCESS_TOKEN=

# ─── Docker Compose Prod Secrets ───────────────────────────
# (Used by docker-compose.prod.yml)
DB_PASSWORD=
REDIS_PASSWORD=
